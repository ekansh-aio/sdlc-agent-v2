import streamlit as st
import uuid

# Generated once per process start — changes every time the server restarts.
# Used to detect stale browser sessions connected to a previous server instance.
_SERVER_RUN_ID = str(uuid.uuid4())


def initialize_session_state():
    # If the browser session was connected to a previous server run, clear all
    # auth state so the user is sent back through the landing/auth flow.
    if st.session_state.get("_server_run_id") != _SERVER_RUN_ID:
        st.session_state.clear()
        st.session_state["_server_run_id"] = _SERVER_RUN_ID

    defaults = {
        "selected_helper":          None,
        "selected_input_type":      None,
        "jira_auth_popup_actioned": False,
        "jira_user_authenticated":  False,
        "jira_display_count":       200,
        "jira_ids_max_results":     200,
        "free_text_input":          None,
        "free_text_response":       None,
        "jira_selected":            [],
        "rewritten_content":        {},
        "pushed_status":            {},
        "logged_in_user":           None,
        "invalid_len_input":        False,
        "jira_username":            None,
        "jira_password":            None,
        "show_jira_login":          False,
        "tcg_selected_btn":         "Manual",
        "previous_jira_selected":   [],
        "_prev_input_type":         None,
    }

    for key, value in defaults.items():
        if key not in st.session_state:
            st.session_state[key] = value
